# API keys required for the mcp-SADE-ME project.
# Copy this file to '.env' and fill in your actual credentials.

# OpenAI API Key (Required for chat agent and summary tools)
OPENAI_API_KEY="your_openai_api_key_here"

# Meteostat API Key from RapidAPI (Required for hourly weather data)
# Host name: meteostat.p.rapidapi.com
METEOSTAT_API_KEY="your_meteostat_rapidapi_key_here"

# ENTSO-E security token (Required for power generation mix data)
ENTSOE_API_KEY="your_entsoe_api_key_here"

# Optional OpenWeather API Key (if needed)
OPENWEATHER_API_KEY="your_openweather_api_key_here"

# Optional LLM Model choice (defaults to gpt-4o-mini if omitted)
# ENERGY_CHAT_MODEL="gpt-4o-mini"
